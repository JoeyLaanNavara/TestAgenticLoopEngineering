{
  "name": "vue",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/vue/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd packages/core && pnpm exec stencil build",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["^build"]
    }
  },
  "tags": ["scope:vue", "type:lib"]
}
