{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": false,
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": false,
    "paths": {
      "@my-org/core": ["packages/core/src/index.ts"],
      "@my-org/angular": ["packages/angular/src/index.ts"],
      "@my-org/react": ["packages/react/src/index.ts"],
      "@my-org/vue": ["packages/vue/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
